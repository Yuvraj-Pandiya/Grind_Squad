// GrindSquad — Prisma Schema
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────
// ENUMS
// ─────────────────────────────────────

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum Platform {
  LEETCODE
  GFG
  CODEFORCES
  OTHER
}

enum SquadRole {
  OWNER
  ADMIN
  MEMBER
}

enum DuelStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
  TIMED_OUT
}

enum NotificationType {
  DUEL_INVITE
  DUEL_RESULT
  PROBLEM_SHARED
  SQUAD_INVITE
  BADGE_EARNED
  WEAKNESS_ALERT
}

// ─────────────────────────────────────
// MODELS
// ─────────────────────────────────────

model User {
  id          String   @id @default(uuid())
  clerkId     String   @unique          // Clerk external ID
  username    String   @unique
  email       String   @unique
  avatarUrl   String?
  bio         String?
  streak      Int      @default(0)
  maxStreak   Int      @default(0)
  totalPoints Int      @default(0)
  lastSolvedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  squadMemberships  SquadMember[]
  solves            UserSolve[]
  duelsAsChallenger Duel[]        @relation("Challenger")
  duelsAsOpponent   Duel[]        @relation("Opponent")
  duelsWon          Duel[]        @relation("Winner")
  discussions       Discussion[]
  reactions         Reaction[]
  badges            UserBadge[]
  notifications     Notification[]
  sharedProblems    SquadProblem[]

  @@map("users")
}

model Squad {
  id          String   @id @default(uuid())
  name        String
  description String?
  inviteCode  String   @unique @default(cuid())
  isPublic    Boolean  @default(false)
  avatarUrl   String?
  bannerUrl   String?
  tags        String[]             // e.g. ["FAANG", "graphs", "placement-2025"]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  members     SquadMember[]
  problems    SquadProblem[]
  discussions Discussion[]
  duels       Duel[]

  @@map("squads")
}

model SquadMember {
  id       String    @id @default(uuid())
  role     SquadRole @default(MEMBER)
  points   Int       @default(0)
  joinedAt DateTime  @default(now())

  userId   String
  squadId  String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  squad    Squad  @relation(fields: [squadId], references: [id], onDelete: Cascade)

  @@unique([userId, squadId])
  @@map("squad_members")
}

model Problem {
  id         String     @id @default(uuid())
  slug       String     @unique        // normalized identifier e.g. "two-sum"
  title      String
  url        String
  difficulty Difficulty
  platform   Platform
  tags       String[]                  // internal taxonomy tags
  createdAt  DateTime   @default(now())

  // Relations
  squadProblems SquadProblem[]
  solves        UserSolve[]
  discussions   Discussion[]
  duels         Duel[]

  @@map("problems")
}

// Join table: a problem shared inside a specific squad
model SquadProblem {
  id        String   @id @default(uuid())
  note      String?                    // sharer's message e.g. "sneaky edge case!"
  sharedAt  DateTime @default(now())

  problemId String
  squadId   String
  sharedById String
  problem   Problem @relation(fields: [problemId], references: [id])
  squad     Squad   @relation(fields: [squadId], references: [id], onDelete: Cascade)
  sharedBy  User    @relation(fields: [sharedById], references: [id])

  @@unique([problemId, squadId])
  @@map("squad_problems")
}

model UserSolve {
  id           String   @id @default(uuid())
  timeTaken    Int?                     // minutes
  approachNote String?                  // optional write-up
  solvedAt     DateTime @default(now())

  userId    String
  problemId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem   Problem @relation(fields: [problemId], references: [id])

  @@unique([userId, problemId])
  @@map("user_solves")
}

model Duel {
  id         String     @id @default(uuid())
  status     DuelStatus @default(PENDING)
  startedAt  DateTime?
  endedAt    DateTime?
  timeLimit  Int        @default(60)   // minutes
  createdAt  DateTime   @default(now())

  challengerId String
  opponentId   String
  problemId    String
  squadId      String
  winnerId     String?

  challenger User    @relation("Challenger", fields: [challengerId], references: [id])
  opponent   User    @relation("Opponent",   fields: [opponentId],   references: [id])
  problem    Problem @relation(fields: [problemId], references: [id])
  squad      Squad   @relation(fields: [squadId],   references: [id])
  winner     User?   @relation("Winner", fields: [winnerId], references: [id])

  @@map("duels")
}

model Discussion {
  id        String   @id @default(uuid())
  content   String
  isSpoiler Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String
  problemId String
  squadId   String
  parentId  String?                    // for nested replies

  user      User       @relation(fields: [userId],    references: [id], onDelete: Cascade)
  problem   Problem    @relation(fields: [problemId], references: [id])
  squad     Squad      @relation(fields: [squadId],   references: [id], onDelete: Cascade)
  parent    Discussion? @relation("Replies", fields: [parentId], references: [id])
  replies   Discussion[] @relation("Replies")
  reactions Reaction[]

  @@map("discussions")
}

model Reaction {
  id    String @id @default(uuid())
  emoji String                         // "🧠" | "🔥" | "💀" | "👀"

  userId       String
  discussionId String
  user         User       @relation(fields: [userId],       references: [id], onDelete: Cascade)
  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)

  @@unique([userId, discussionId, emoji])
  @@map("reactions")
}

model Badge {
  id          String @id @default(uuid())
  key         String @unique            // e.g. "streak_lord", "graph_wizard"
  name        String
  description String
  icon        String                    // emoji or icon name
  users       UserBadge[]

  @@map("badges")
}

model UserBadge {
  id       String   @id @default(uuid())
  earnedAt DateTime @default(now())

  userId  String
  badgeId String
  user    User  @relation(fields: [userId],  references: [id], onDelete: Cascade)
  badge   Badge @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
  @@map("user_badges")
}

model Notification {
  id        String           @id @default(uuid())
  type      NotificationType
  payload   Json                         // flexible: duel invite, badge earned, etc.
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}
