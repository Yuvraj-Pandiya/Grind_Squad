# ================================
# GrindSquad — Server Environment
# ================================
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file.

# --- Database (Supabase) ---
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# --- Redis (Upstash) ---
REDIS_URL="https://[YOUR_UPSTASH_URL].upstash.io"
REDIS_TOKEN="your-upstash-token"

# --- Auth (Clerk) ---
CLERK_SECRET_KEY="sk_test_..."

# --- JWT ---
JWT_SECRET="replace-with-a-long-random-secret-min-32-chars"

# --- Server ---
PORT=4000
NODE_ENV=development

# --- CORS ---
CLIENT_URL="http://localhost:3000"

# --- Email (Resend) ---
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@grindsquad.dev"
